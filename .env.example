# Junando - Environment Configuration Example
# Copy to .env.local, .env.staging, or .env.production

# --- LLM Config ---
LLM_PROVIDER=qwen          # gemini | claude | openrouter | qwen
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=                 # opcional — usa default del provider si está vacío

# --- LLM Fallback Chain (OpenRouter only) ---
# Comma-separated list of free models to try after primary exhausts 429 retries.
# Leave empty to disable fallback (default: no fallback).
LLM_FALLBACK_MODELS=
# Wall-clock timeout in ms for the entire fallback chain (default: 60000).
LLM_FALLBACK_TIMEOUT_MS=60000

# --- Notifier Config ---
# Select which notifier to use (default: slack)
NOTIFIER_TYPE=slack            # slack | teams

# --- Slack Config (required when NOTIFIER_TYPE=slack) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL='#alerts'

# --- Microsoft Teams Config (required when NOTIFIER_TYPE=teams) ---
# Use a Power Automate Workflow webhook URL (powerautomate.com).
# The URL MUST include the api-version= query parameter (Microsoft requirement).
# Example: https://prod-XX.westus.logic.azure.com/workflows/.../invoke?api-version=2024-10-01&sp=...
# TEAMS_WEBHOOK_URL=https://prod-XX.powerautomate.com/workflows/.../invoke?api-version=2024-10-01&sp=...

# --- Monitoring ---
LOKI_URL=http://localhost:3100
REDIS_URL=redis://localhost:6379

# --- Clustering / Dedup ---
DEDUP_TTL_SECONDS=300       # segundos antes que expire la clave de dedup
CLUSTER_WINDOW_MS=120000    # ventana en ms para agrupar alertas relacionadas (default: 2 min)

# --- CSV Input Adapter (Worker) ---
# Optional: parse CSV bodies from SQS messages instead of JSON.
# Auto-detected when SQS body contains commas and no leading { or [
CSV_SERVICE_COL=0          # Column index (0-based) for service name
CSV_MESSAGE_COL=1          # Column index for alert message
CSV_SEVERITY_COL=2         # Column index for severity (error/warning/success)
CSV_TIMESTAMP_COL=3        # Column index for timestamp (ISO 8601 or Unix)
# CSV_FINGERPRINT_COL=4    # Optional: column for custom fingerprint
# CSV_ENDPOINT_COL=5       # Optional: column for endpoint path
# CSV_EXTRA_LABELS=env=prod # Optional: static labels as key=val,key=val

# --- SQS (vacío en local, CDK lo inyecta en AWS) ---
SQS_QUEUE_URL=

# --- APP URL (CDK lo inyecta en AWS; en local el adapter usa https://junando.app) ---
# APP_URL=http://localhost:4000

# --- General ---
NODE_ENV=development
LOG_LEVEL=info              # trace | debug | info | warn | error

# --- Infrastructure ---
# For local dev: http://localhost:4000/webhook/alert
# For Docker: http://host.docker-internal:4000/webhook/alert
# For AWS: https://your-lambda-url.lambda-url.region.on.aws/
JUNANDO_WEBHOOK_URL=http://localhost:4000/webhook/alert

