# -----------------------------------------------------------------------------
# Junando - Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to .env.local and replace the placeholders with actual values.
# -----------------------------------------------------------------------------

# AI Provider Configuration ('gemini' or 'claude')
LLM_PROVIDER=gemini
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gemini-1.5-pro

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_CHANNEL=#incidents

# Infrastructure
LOKI_URL=http://localhost:3100
REDIS_URL=redis://localhost:6379

# Queue Configuration (Leave empty for local development bypass)
SQS_QUEUE_URL=

# Application Settings
DEDUP_TTL_SECONDS=300
CLUSTER_WINDOW_MS=120000
LOG_LEVEL=info
NODE_ENV=development

# Port for local dev server
PORT=4000
