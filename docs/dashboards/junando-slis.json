{
  "uid": "junando-slis",
  "title": "Junando SLIs",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Ingest Latency p95",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-local"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(junando_webhook_duration_seconds_bucket{status=\"success\"}[5m]))",
          "legendFormat": "p95 latency (s)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Dedup Ratio",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-local"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(junando_dedup_duplicate_total[5m]) / (rate(junando_dedup_new_total[5m]) + rate(junando_dedup_duplicate_total[5m])) or vector(0)",
          "legendFormat": "Dedup ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Incident Throughput",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-local"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(junando_alerts_processed_total[5m])",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Notification Outcomes",
      "type": "barchart",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-local"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(junando_notifications_total[5m])",
          "legendFormat": "{{channel}} / {{outcome}}",
          "refId": "A"
        }
      ]
    }
  ]
}
