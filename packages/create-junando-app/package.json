{
  "name": "create-junando-app",
  "version": "0.12.2",
  "description": "Scaffold a new Junando alerting app from the express-end-to-end template",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "create-junando-app": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist",
    "template",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GerMoren/junando.git",
    "directory": "packages/create-junando-app"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/sync-template.js",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist template",
    "prepublishOnly": "pnpm clean && pnpm build && node scripts/verify-tarball.js"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
