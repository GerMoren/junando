{
  "name": "@junando/ingest",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./loki-http-client": {
      "development": "./src/adapters/loki/loki-http-client.ts",
      "default": "./dist/adapters/loki/loki-http-client.js"
    }
  },
  "scripts": {
    "prepare": "[ -d src ] && tsup || true",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1045.0",
    "@junando/core": "workspace:*",
    "yaml": "^2.7.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
