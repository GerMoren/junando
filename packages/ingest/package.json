{
  "name": "@junando/ingest",
  "version": "0.11.0",
  "description": "Alert ingestion adapter — maps external monitoring payloads into Junando's domain model",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GerMoren/junando.git",
    "directory": "packages/ingest"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "[ -d src ] && tsup || true",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1069.0",
    "yaml": "^2.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@junando/core": "workspace:*",
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./loki-http-client": {
      "development": "./src/adapters/loki/loki-http-client.ts",
      "import": "./dist/loki-http-client.js",
      "require": "./dist/loki-http-client.cjs",
      "default": "./dist/loki-http-client.js"
    }
  }
}
