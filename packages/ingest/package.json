{
  "name": "@junando/ingest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@junando/core": "workspace:*",
    "yaml": "^2.7.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
