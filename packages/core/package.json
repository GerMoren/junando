{
  "name": "@junando/core",
  "version": "0.11.0",
  "description": "Core domain types, interfaces, and shared utilities for the Junando alerting platform",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GerMoren/junando.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@google/generative-ai": "^0.24.1",
    "@types/opossum": "^8.1.9",
    "ioredis": "^5.11.1",
    "opossum": "^10.0.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.0.0",
    "typescript": "^7.0.2"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./shared/metrics": {
      "development": "./src/shared/metrics/index.ts",
      "default": "./dist/shared/metrics/index.js"
    }
  }
}
