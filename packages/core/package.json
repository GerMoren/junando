{
  "name": "@junando/core",
  "version": "0.7.1",
  "description": "Core domain types, interfaces, and shared utilities for the Junando alerting platform",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GerMoren/junando.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/generative-ai": "^0.21.0",
    "@types/opossum": "^8.1.9",
    "ioredis": "^5.10.1",
    "opossum": "^9.0.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./shared/metrics": {
      "development": "./src/shared/metrics/index.ts",
      "default": "./dist/shared/metrics/index.js"
    }
  }
}
