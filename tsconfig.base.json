{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@domain/*": ["./packages/core/src/domain/*"],
      "@application/*": ["./packages/core/src/application/*"],
      "@infrastructure/*": ["./packages/core/src/infrastructure/*"],
      "@shared/*": ["./packages/core/src/shared/*"],
      "@junando/core": ["./packages/core/src/index.ts"],
      "@junando/ingest": ["./packages/ingest/src/index.ts"],
      "@junando/ingest/loki-http-client": ["./packages/ingest/src/adapters/loki/loki-http-client.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
