      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/getting-started/" style="display:inline-flex;align-items:center;gap:0.375rem;padding:0.75rem 1.75rem;border-radius:0.5rem;font-size:1rem;font-weight:600;color:#fff;background:linear-gradient(135deg,#3b82f6,#2563eb);text-decoration:none;box-shadow:0 4px 14px rgba(59,130,246,0.3);transition:all 0.2s ease;">
