{
  "name": "junando",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint --deny-warnings packages/*/src",
    "format": "prettier --write packages/*/src scripts",
    "typecheck": "tsc --noEmit",
    "dev:webhook": "tsx --env-file=.env.local --watch scripts/dev-server.ts | pino-pretty",
    "setup:local": "docker compose -f docker/docker-compose.yml up -d && echo '\n✅ Stack ready. Grafana: http://localhost:3000'",
    "teardown:local": "docker compose -f docker/docker-compose.yml down -v",
    "generate:alert": "tsx --env-file=.env.local scripts/generate-alert.ts",
    "generate:alert:prod": "tsx --env-file=.env.production scripts/generate-alert.ts",
    "simulate:incident": "tsx --env-file=.env.local scripts/simulate-incident.ts",
    "simulate:incident:prod": "tsx --env-file=.env.production scripts/simulate-incident.ts -- --target=webhook",
    "simulate:db-outage:prod": "tsx --env-file=.env.production scripts/simulate-incident.ts -- --scenario=db_outage --target=webhook",
    "simulate:bad-deploy:prod": "tsx --env-file=.env.production scripts/simulate-incident.ts -- --scenario=bad_deploy --target=webhook",
    "simulate:latency:prod": "tsx --env-file=.env.production scripts/simulate-incident.ts -- --scenario=latency_spike --target=webhook",
    "logs:webhook": "aws logs tail /aws/lambda/junando-webhook --follow --format short",
    "logs:worker": "aws logs tail /aws/lambda/junando-worker --follow --format short",
    "ingest:build": "tsup --config scripts/tsup.ingest.config.ts",
    "ingest:dev": "tsx scripts/ingest-server.ts",
    "worker:local": "tsx --env-file=.env.local scripts/worker-local.ts",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^2.1.9",
    "oxlint": "^0.13.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1045.0",
    "@aws-sdk/client-ssm": "^3.1045.0",
    "@types/ioredis": "^5.0.0",
    "bottleneck": "^2.19.5",
    "ioredis": "^5.10.1",
    "opossum": "^9.0.0",
    "prom-client": "^15.1.3"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "pnpm": {
    "overrides": {
      "ioredis": "^5.10.1"
    }
  }
}
